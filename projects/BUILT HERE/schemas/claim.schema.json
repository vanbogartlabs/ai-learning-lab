{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Claim Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "statement",
    "claim_type",
    "status",
    "confidence",
    "supporting_sources"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^CLM-[0-9]{5}$"
    },
    "statement": {
      "type": "string"
    },
    "claim_type": {
      "enum": [
        "fact",
        "interpretation",
        "causal",
        "comparative",
        "quantitative",
        "contextual"
      ]
    },
    "status": {
      "enum": [
        "proposed",
        "active",
        "under_review",
        "approved",
        "locked",
        "rejected",
        "superseded",
        "archived"
      ]
    },
    "confidence": {
      "enum": [
        "high",
        "medium",
        "low",
        "contested",
        "unassessed"
      ]
    },
    "supporting_sources": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^SRC-[0-9]{5}$"
      }
    },
    "contradicting_sources": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^SRC-[0-9]{5}$"
      }
    },
    "related_entities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "related_events": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^EVT-[0-9]{5}$"
      }
    },
    "research_questions": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^RQ-[0-9]{3}$"
      }
    },
    "chapter_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^CH-[0-9]{2}$"
      }
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
