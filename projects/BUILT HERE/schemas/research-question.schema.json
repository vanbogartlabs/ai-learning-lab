{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Research Question",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "question",
    "priority",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^RQ-[0-9]{3}$"
    },
    "title": {
      "type": "string"
    },
    "question": {
      "type": "string"
    },
    "why_it_matters": {
      "type": [
        "string",
        "null"
      ]
    },
    "evidence_required": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "priority": {
      "enum": [
        "critical",
        "high",
        "medium",
        "low",
        "proposed"
      ]
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "enum": [
        "proposed",
        "approved",
        "ready",
        "in_progress",
        "blocked",
        "answered",
        "closed"
      ]
    },
    "assigned_role": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^SRC-[0-9]{5}$"
      }
    },
    "claim_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^CLM-[0-9]{5}$"
      }
    },
    "confidence": {
      "enum": [
        "high",
        "medium",
        "low",
        "contested",
        "unassessed"
      ]
    },
    "unresolved_issues": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
