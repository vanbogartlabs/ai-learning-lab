{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Source Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "source_type",
    "status",
    "confidence"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^SRC-[0-9]{5}$"
    },
    "title": {
      "type": "string"
    },
    "author": {
      "type": [
        "string",
        "null"
      ]
    },
    "publisher": {
      "type": [
        "string",
        "null"
      ]
    },
    "publication_date": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_type": {
      "type": "string"
    },
    "url": {
      "type": [
        "string",
        "null"
      ]
    },
    "repository_location": {
      "type": [
        "string",
        "null"
      ]
    },
    "accessed_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "summary": {
      "type": [
        "string",
        "null"
      ]
    },
    "research_questions": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^RQ-[0-9]{3}$"
      }
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "claims_supported": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^CLM-[0-9]{5}$"
      }
    },
    "claims_contradicted": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^CLM-[0-9]{5}$"
      }
    },
    "confidence": {
      "enum": [
        "high",
        "medium",
        "low",
        "unassessed"
      ]
    },
    "status": {
      "enum": [
        "proposed",
        "active",
        "under_review",
        "approved",
        "locked",
        "rejected",
        "superseded",
        "archived"
      ]
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
