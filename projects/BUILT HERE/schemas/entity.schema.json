{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Entity Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "entity_type",
    "canonical_name",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^(PER|COM|ORG|PLC)-[0-9]{5}$"
    },
    "entity_type": {
      "enum": [
        "person",
        "company",
        "organization",
        "place"
      ]
    },
    "canonical_name": {
      "type": "string"
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "start_date": {
      "type": [
        "string",
        "null"
      ]
    },
    "end_date": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^SRC-[0-9]{5}$"
      }
    },
    "claim_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^CLM-[0-9]{5}$"
      }
    },
    "status": {
      "enum": [
        "proposed",
        "active",
        "under_review",
        "approved",
        "locked",
        "rejected",
        "superseded",
        "archived"
      ]
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
